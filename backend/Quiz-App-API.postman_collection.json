              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quiz_id\": 1,\n  \"questions\": [\n    {\n      \"question_type\": \"mcq\",\n      \"question_text\": \"What is 2+2?\",\n      \"marks\": 5,\n      \"difficulty\": \"easy\",\n      \"options\": [\n        {\"option_text\": \"3\", \"is_correct\": false},\n        {\"option_text\": \"4\", \"is_correct\": true},\n        {\"option_text\": \"5\", \"is_correct\": false}\n      ]\n    },\n    {\n      \"question_type\": \"mcq\",\n      \"question_text\": \"What is 10/2?\",\n      \"marks\": 5,\n      \"difficulty\": \"easy\",\n      \"options\": [\n        {\"option_text\": \"3\", \"is_correct\": false},\n        {\"option_text\": \"4\", \"is_correct\": false},\n        {\"option_text\": \"5\", \"is_correct\": true}\n      ]\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/questions/bulk",
              "host": ["{{baseUrl}}"],
              "path": ["questions", "bulk"]
            },
            "description": "Bulk import multiple questions at once with their options (Admin/Instructor only)"
          }
        }
      ]
    },
    {
      "name": "Attempts",
      "description": "Quiz attempt endpoints - Start, Submit, View attempts",
      "item": [
        {
          "name": "Start Attempt",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quiz_id\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/attempts/start",
              "host": ["{{baseUrl}}"],
              "path": ["attempts", "start"]
            },
            "description": "Start a new quiz attempt (Student only).\n- Validates quiz is published/active and within time window\n- Resumes existing in-progress attempt if found\n- Returns attempt details"
          }
        },
        {
          "name": "Submit Attempt",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answers\": [\n    {\n      \"question_id\": 1,\n      \"selected_option_id\": 1\n    },\n    {\n      \"question_id\": 2,\n      \"selected_option_id\": 6\n    },\n    {\n      \"question_id\": 3,\n      \"selected_option_id\": [1, 3, 5]\n    },\n    {\n      \"question_id\": 4,\n      \"selected_option_id\": 10\n    },\n    {\n      \"question_id\": 5,\n      \"answer_text\": \"2a\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/attempts/{{attemptId}}/submit",
              "host": ["{{baseUrl}}"],
              "path": ["attempts", "{{attemptId}}", "submit"]
            },
            "description": "Submit quiz answers for auto-grading.\n\n- For MCQ/TrueFalse: send selected_option_id (single)\n- For Multiple Correct: send selected_option_id as array\n- For Fill Blanks: send answer_text\n- Negative marking applied if quiz has negative_marking = true"
          }
        },
        {
          "name": "Get Attempt Details",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/attempts/{{attemptId}}",
              "host": ["{{baseUrl}}"],
              "path": ["attempts", "{{attemptId}}"]
            },
            "description": "Get attempt details with answers (student's own attempts only)"
          }
        },
        {
          "name": "Get My Attempts",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/attempts",
              "host": ["{{baseUrl}}"],
              "path": ["attempts"]
            },
            "description": "Get all attempts for the authenticated student"
          }
        }
      ]
    },
